# ============================================================================
# Tor HTTPS Bridge Proxy — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values as needed.
# All variables use the TOR_BRIDGE_ prefix.
# ============================================================================

# --- Tor SOCKS5 ---
# TOR_BRIDGE_TOR_SOCKS_HOST=127.0.0.1
# TOR_BRIDGE_TOR_SOCKS_PORT=9050

# --- HTTPS Proxy ---
# TOR_BRIDGE_HTTPS_PROXY_HOST=127.0.0.1
# TOR_BRIDGE_HTTPS_PROXY_PORT=3128

# --- Performance ---
# TOR_BRIDGE_BUFFER_SIZE=8192
# TOR_BRIDGE_BACKLOG=100
# TOR_BRIDGE_MAX_REQUEST_SIZE=65535

# --- Timeouts ---
# TOR_BRIDGE_CONNECT_TIMEOUT=30
# TOR_BRIDGE_READ_TIMEOUT=60

# --- Logging ---
# TOR_BRIDGE_LOG_LEVEL=INFO

# --- Stealth Mode (Header Sanitization) ---
# Enable to sanitize HTTP headers (remove locale, OS info, internal IPs)
# TOR_BRIDGE_SANITIZE_HEADERS=false

# Custom User-Agent for sanitized requests (default: Chrome 125 en)
# TOR_BRIDGE_OVERRIDE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

# Custom Accept-Language for sanitized requests (default: en-US)
# TOR_BRIDGE_OVERRIDE_ACCEPT_LANGUAGE=en-US,en;q=0.9

# --- Config file (optional, overrides .env defaults but not env vars) ---
# TOR_BRIDGE_CONFIG_FILE=